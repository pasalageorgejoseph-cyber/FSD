<h3>Login</h3>
Username:<input id="name"><br><br>
Password:<input id="password" type="password"><br><br>
<button onclick="login()">Submit</button>
<script>
function login() {
  $.post("/login", {
name: $("#name").val(),
password: $("#password").val() }, function(res) {
if(res.login){
alert("JWT Token:\n\n" + res.token);   
      } else {
alert("\nAuthentication Failed");        
      }
    });
}
</script>
