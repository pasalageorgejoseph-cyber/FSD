# Register.html

<!DOCTYPE html>
<html>
<head>
<script>
function validate(){
  let f = document.f.name.value;
  let p = document.f.phone.value;
  let m = document.f.email.value;
    for(let i in f){
    let ch = f.charCodeAt(i);
    if(ch<65 || ch>90 && ch<97 || ch>122){
      alert("Invalid Name"); return false;
    }
  }
   if(p.length != 10){
    alert("Phone must be 10 digits"); return false;
  }
  var reg = /^([a-zA-Z][a-zA-Z0-9\.-]+)@([a-zA-Z-]+).([a-z]{2,8})(.[a-z]{2,8})?$/;
  if(!reg.test(m)){
    alert("Invalid Email"); return false;
  }
  localStorage.setItem("name",f);
  localStorage.setItem("phone",p);
  localStorage.setItem("email",m);
  alert("Registration Successful");
  return true;
}
</script>
</head>
<body>
<h2>Register</h2>
<form name="f" action="/login" onsubmit="return validate()">
  Name: <input type="text" name="name"><br><br>
  Phone: <input type="text" name="phone"><br><br>
  Email: <input type="text" name="email"><br><br>
  <input type="submit" value="Register">
</form>
</body>
</html>

