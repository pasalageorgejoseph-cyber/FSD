# Login.html

<!DOCTYPE html>
<html>
<head>
<script>
function login(){
  let m = document.f.email.value;
  let storedEmail = localStorage.getItem("email");
  if(m == storedEmail){
    alert("Login Success");
    return true;
  }else{
    alert("Invalid Email");
    return false;
  }
}
</script>
</head>
<body>
<h2>Login</h2>
<form name="f" action="/profile" onsubmit="return login()">
  Email: <input type="text" name="email"><br><br>
  <input type="submit" value="Login">
</form>
</body>
</html>

